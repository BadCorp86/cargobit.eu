generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Address {
  id                                             String      @id
  userId                                         String?
  companyId                                      String?
  label                                          String?
  contactName                                    String?
  contactPhone                                   String?
  street                                         String
  streetNumber                                   String?
  postalCode                                     String
  city                                           String
  state                                          String?
  country                                        String
  latitude                                       Float?
  longitude                                      Float?
  isDefault                                      Boolean     @default(false)
  createdAt                                      DateTime    @default(now())
  updatedAt                                      DateTime
  Company                                        Company?    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  User                                           User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  Transport_Transport_deliveryAddressIdToAddress Transport[] @relation("Transport_deliveryAddressIdToAddress")
  Transport_Transport_pickupAddressIdToAddress   Transport[] @relation("Transport_pickupAddressIdToAddress")

  @@index([country])
  @@index([companyId])
  @@index([userId])
}

model AdminAuditLog {
  id         String    @id
  adminId    String
  action     String
  entityType String
  entityId   String?
  dataBefore String?
  dataAfter  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  AdminUser  AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([adminId])
}

model AdminSession {
  id               String    @id
  adminId          String
  token            String    @unique
  refreshToken     String    @unique
  ipAddress        String
  userAgent        String?
  deviceId         String?
  expiresAt        DateTime
  refreshExpiresAt DateTime
  createdAt        DateTime  @default(now())
  lastActivity     DateTime  @default(now())
  AdminUser        AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([adminId])
}

model AdminUser {
  id             String          @id
  email          String          @unique
  passwordHash   String
  totpSecret     String?
  is2faEnabled   Boolean         @default(false)
  backupCodes    String?
  role           String          @default("SUPPORT")
  isActive       Boolean         @default(true)
  lastLoginAt    DateTime?
  failedAttempts Int             @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  AdminAuditLog  AdminAuditLog[]
  AdminSession   AdminSession[]

  @@index([isActive])
  @@index([role])
  @@index([email])
}

model Assignment {
  id          String    @id
  transportId String    @unique
  driverId    String
  vehicleId   String
  assignedBy  String
  assignedAt  DateTime  @default(now())
  Vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  Driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  Transport   Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([transportId])
}

model AuditLog {
  id         String   @id
  userId     String?
  action     String
  entityType String
  entityId   String?
  dataBefore String?
  dataAfter  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  User       User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([userId])
}

model BorderCrossing {
  id              String   @id
  fromCountry     String
  toCountry       String
  crossingName    String
  latitude        Float?
  longitude       Float?
  adrAllowed      Boolean  @default(true)
  tunnelCode      String?
  open24h         Boolean  @default(true)
  openingHours    String?
  avgWaitMinutes  Int?
  customsRequired Boolean  @default(true)
  customsType     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@unique([fromCountry, toCountry, crossingName])
  @@index([toCountry])
  @@index([fromCountry])
}

model Campaign {
  id            String          @id
  companyId     String?
  userId        String
  name          String
  description   String?
  position      String?
  bannerUrl     String?
  targetUrl     String?
  budget        Float           @default(0)
  spentAmount   Float           @default(0)
  currency      String          @default("EUR")
  status        String          @default("DRAFT")
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  User          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  Company       Company?        @relation(fields: [companyId], references: [id])
  CampaignStats CampaignStats[]

  @@index([status])
  @@index([userId])
  @@index([companyId])
}

model CampaignStats {
  id          String   @id
  campaignId  String
  date        DateTime @default(now())
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  Campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
}

model Commission {
  id                String    @id
  transportId       String
  plan              String    @default("FREE")
  commissionPercent Float
  commissionAmount  Float
  walletFeePercent  Float
  walletFeeAmount   Float
  createdAt         DateTime  @default(now())
  Transport         Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)

  @@index([transportId])
}

model Company {
  id                 String        @id
  name               String
  type               String        @default("SHIPPER")
  vatNumber          String?       @unique
  registrationNumber String?
  country            String
  status             String        @default("PENDING")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime
  Address            Address[]
  Campaign           Campaign[]
  CompanyPlan        CompanyPlan[]
  CompanyUser        CompanyUser[]
  Driver             Driver[]
  Vehicle            Vehicle[]
  Wallet             Wallet?

  @@index([country])
  @@index([name])
}

model CompanyPlan {
  id        String    @id
  companyId String
  planId    String
  validFrom DateTime  @default(now())
  validTo   DateTime?
  createdAt DateTime  @default(now())
  Plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  Company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([companyId])
}

model CompanyUser {
  companyId     String
  userId        String
  roleInCompany String   @default("member")
  createdAt     DateTime @default(now())
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, userId])
  @@index([userId])
  @@index([companyId])
}

model Dispute {
  id                  String              @id
  jobId               String
  createdById         String
  againstId           String?
  reason              String
  subject             String
  description         String
  disputedAmountCents Int?
  status              String              @default("OPEN")
  resolution          String?
  resolutionText      String?
  refundAmountCents   Int?
  assignedToId        String?
  resolvedById        String?
  resolvedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime
  DisputeAttachment   DisputeAttachment[]
  DisputeAuditEvent   DisputeAuditEvent[]
  DisputeMessage      DisputeMessage[]

  @@index([createdAt])
  @@index([reason])
  @@index([status])
  @@index([createdById])
  @@index([jobId])
}

model DisputeAttachment {
  id         String   @id
  disputeId  String
  messageId  String?
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int?
  uploadedBy String
  createdAt  DateTime @default(now())
  Dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

model DisputeAuditEvent {
  id        String   @id
  disputeId String
  eventType String
  oldStatus String?
  newStatus String?
  adminId   String?
  metadata  String?
  createdAt DateTime @default(now())
  Dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([eventType])
  @@index([disputeId])
}

model DisputeMessage {
  id          String   @id
  disputeId   String
  senderId    String
  senderType  String
  message     String
  attachments String?
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  Dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([senderId])
  @@index([disputeId])
}

model Document {
  id          String     @id
  transportId String?
  type        String
  name        String
  description String?
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  isGenerated Boolean    @default(false)
  isSigned    Boolean    @default(false)
  signedAt    DateTime?
  signedByUrl String?
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  Transport   Transport? @relation(fields: [transportId], references: [id])

  @@index([type])
  @@index([transportId])
}

model Driver {
  id                      String              @id
  userId                  String              @unique
  companyId               String?
  licenseNumber           String?
  licenseClass            String?
  licenseExpiry           DateTime?
  driverCardNumber        String?
  driverCardExpiry        DateTime?
  adrLicense              Boolean             @default(false)
  adrClasses              String?
  adrExpiry               DateTime?
  internationalExperience Boolean             @default(false)
  ratingAvg               Float               @default(0)
  ratingCount             Int                 @default(0)
  completedTransports     Int                 @default(0)
  cancelledTransports     Int                 @default(0)
  damageCount             Int                 @default(0)
  lastDamageAt            DateTime?
  isAvailable             Boolean             @default(true)
  currentLocation         String?
  spokenLanguages         String?
  yearsExperience         Int?
  vehicleExperience       String?
  countryExperience       String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime
  Assignment              Assignment[]
  Company                 Company?            @relation(fields: [companyId], references: [id])
  User                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  DriverPermission        DriverPermission[]
  DriverVehicle           DriverVehicle[]
  MatchingCandidate       MatchingCandidate[]
  Offer                   Offer[]
  TrackingPoint           TrackingPoint[]

  @@index([isAvailable])
  @@index([companyId])
  @@index([userId])
}

model DriverPermission {
  id             String    @id
  driverId       String
  countryCode    String
  countryName    String
  isAllowed      Boolean   @default(true)
  allowedAt      DateTime?
  expiresAt      DateTime?
  visaRequired   Boolean   @default(false)
  visaValid      Boolean   @default(false)
  visaExpiry     DateTime?
  tripsCompleted Int       @default(0)
  lastTripAt     DateTime?
  documentUrl    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  Driver         Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, countryCode])
  @@index([isAllowed])
  @@index([countryCode])
  @@index([driverId])
}

model DriverVehicle {
  driverId   String
  vehicleId  String
  isPrimary  Boolean  @default(false)
  assignedAt DateTime @default(now())
  Vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  Driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@id([driverId, vehicleId])
  @@index([vehicleId])
  @@index([driverId])
}

model InsurancePolicy {
  id                String           @id
  partnerId         String
  productId         String
  transportId       String?
  policyNumber      String           @unique
  status            String           @default("active")
  coverageEur       Float
  premiumEur        Float
  deductibleEur     Float
  insuredUserId     String?
  insuredName       String
  insuredEmail      String
  riskLevel         String?
  riskScore         Int?
  pickupCountry     String?
  deliveryCountry   String?
  transitCountries  String?
  cargoDescription  String?
  cargoValueEur     Float?
  basePremium       Float
  riskSurcharge     Float            @default(0)
  totalPremium      Float
  partnerCommission Float
  validFrom         DateTime
  validUntil        DateTime
  cancelledAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  InsuranceProduct  InsuranceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  Partner           Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
  @@index([productId])
  @@index([partnerId])
}

model InsuranceProduct {
  id                String            @id
  partnerId         String
  name              String
  description       String?
  productCode       String?
  coverageEur       Float
  deductibleEur     Float             @default(0)
  basePremiumEur    Float
  premiumType       String            @default("fixed")
  riskModifiers     String?
  routeModifiers    String?
  cargoModifiers    String?
  coversTheft       Boolean           @default(true)
  coversDelay       Boolean           @default(false)
  coversDamage      Boolean           @default(true)
  coversHazmat      Boolean           @default(false)
  additionalOptions String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  InsurancePolicy   InsurancePolicy[]
  Partner           Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([partnerId])
}

model MatchingCandidate {
  id                   String          @id
  matchingSessionId    String
  driverId             String
  vehicleId            String
  hardFilterPassed     Boolean         @default(false)
  softRulesPassed      Boolean         @default(false)
  fraudSafe            Boolean         @default(true)
  internationalAllowed Boolean         @default(true)
  score                Float           @default(0)
  scoreBreakdown       String?
  status               String          @default("PENDING")
  notifiedAt           DateTime?
  expiresAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime
  Vehicle              Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  Driver               Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  MatchingSession      MatchingSession @relation(fields: [matchingSessionId], references: [id], onDelete: Cascade)

  @@unique([matchingSessionId, driverId, vehicleId])
  @@index([status])
  @@index([score])
  @@index([driverId])
  @@index([matchingSessionId])
}

model MatchingSession {
  id                String              @id
  transportId       String
  status            String              @default("STARTED")
  autoAssign        Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  completedAt       DateTime?
  MatchingCandidate MatchingCandidate[]
  Transport         Transport           @relation(fields: [transportId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([transportId])
}

model Notification {
  id          String    @id
  userId      String
  type        String
  title       String
  message     String
  data        String?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([userId])
}

model Offer {
  id                String    @id
  transportId       String
  driverId          String
  vehicleId         String
  price             Float
  currency          String    @default("EUR")
  message           String?
  estimatedDuration Int?
  status            String    @default("PENDING")
  validUntil        DateTime?
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  Vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  Driver            Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  Transport         Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)

  @@unique([transportId, driverId])
  @@index([status])
  @@index([driverId])
  @@index([transportId])
}

model Partner {
  id                 String              @id
  name               String
  type               String
  contactEmail       String
  contactPhone       String?
  contactPerson      String?
  website            String?
  vatNumber          String?             @unique
  registrationNumber String?
  country            String?
  address            String?
  status             String              @default("PENDING")
  statusReason       String?
  contractUrl        String?
  complianceDocs     String?
  webhookUrl         String?
  testMode           Boolean             @default(true)
  liveModeEnabled    Boolean             @default(false)
  commissionRate     Float               @default(10.0)
  rateLimitPerMin    Int                 @default(300)
  burstLimit         Int                 @default(100)
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  InsurancePolicy    InsurancePolicy[]
  InsuranceProduct   InsuranceProduct[]
  PartnerAdCampaign  PartnerAdCampaign[]
  PartnerAdStat      PartnerAdStat[]
  PartnerApiKey      PartnerApiKey[]
  PartnerBilling     PartnerBilling[]

  @@index([contactEmail])
  @@index([status])
  @@index([type])
}

model PartnerAdCampaign {
  id               String          @id
  partnerId        String
  name             String
  description      String?
  slot             String          @default("MARKETPLACE_SIDEBAR")
  bannerUrl        String?
  bannerAlt        String?
  targetUrl        String
  callToAction     String?
  budgetEur        Float
  spentEur         Float           @default(0)
  currency         String          @default("EUR")
  pricingModel     String          @default("CPC")
  cpcEur           Float?
  cpmEur           Float?
  cpaEur           Float?
  targeting        String?
  languageTarget   String?
  startDate        DateTime?
  endDate          DateTime?
  status           String          @default("DRAFT")
  totalImpressions Int             @default(0)
  totalClicks      Int             @default(0)
  totalConversions Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  Partner          Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  PartnerAdStat    PartnerAdStat[]

  @@index([slot])
  @@index([status])
  @@index([partnerId])
}

model PartnerAdStat {
  id                String            @id
  partnerId         String
  campaignId        String
  date              DateTime
  impressions       Int               @default(0)
  clicks            Int               @default(0)
  conversions       Int               @default(0)
  costEur           Float             @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  PartnerAdCampaign PartnerAdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  Partner           Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([date])
  @@index([campaignId])
  @@index([partnerId])
}

model PartnerApiKey {
  id              String    @id
  partnerId       String
  name            String
  apiKey          String    @unique
  apiKeyPrefix    String
  scopes          String
  status          String    @default("ACTIVE")
  isTestKey       Boolean   @default(true)
  rateLimitPerMin Int?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  revokedReason   String?
  Partner         Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([apiKey])
  @@index([partnerId])
}

model PartnerBilling {
  id               String    @id
  partnerId        String
  invoiceNumber    String    @unique
  type             String
  periodMonth      Int
  periodYear       Int
  grossAmountEur   Float
  commissionEur    Float
  netAmountEur     Float
  vatEur           Float?
  totalEur         Float
  status           String    @default("OPEN")
  paidAt           DateTime?
  paymentMethod    String?
  paymentReference String?
  invoiceUrl       String?
  lineItems        String?
  dueDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  Partner          Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([periodYear, periodMonth])
  @@index([status])
  @@index([partnerId])
}

model Payment {
  id                     String              @id
  paymentIntentId        String?             @unique
  chargeId               String?
  jobId                  String?
  shipperId              String
  transporterId          String?
  amountCents            Int
  currency               String              @default("EUR")
  platformFeeCents       Int                 @default(0)
  transporterAmountCents Int?
  refundedCents          Int                 @default(0)
  status                 String              @default("PENDING")
  lastStripeEventId      String?
  stripeRefundsJson      String?
  lastReconciledAt       DateTime?
  description            String?
  metadata               String?
  paidAt                 DateTime?
  failedAt               DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime
  PaymentAuditEvent      PaymentAuditEvent[]
  Refund                 Refund[]
  StripeRefund           StripeRefund[]
  WalletTransaction      WalletTransaction[]

  @@index([lastReconciledAt])
  @@index([createdAt])
  @@index([status])
  @@index([shipperId])
  @@index([jobId])
  @@index([chargeId])
  @@index([paymentIntentId])
}

model PaymentAuditEvent {
  id        String   @id
  paymentId String
  eventType String
  oldStatus String?
  newStatus String
  adminId   String?
  metadata  String?
  createdAt DateTime @default(now())
  Payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([eventType])
  @@index([paymentId])
}

model Payout {
  id                  String             @id
  userId              String
  amountCents         Int
  currency            String             @default("EUR")
  status              String             @default("PENDING")
  stripeTransferId    String?            @unique
  stripeAccountId     String?
  failureReason       String?
  failureCode         String?
  idempotencyKey      String?            @unique
  initiatedBy         String?
  processedBy         String?
  walletTransactionId String?
  processedAt         DateTime?
  failedAt            DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime
  PayoutAuditEvent    PayoutAuditEvent[]

  @@index([idempotencyKey])
  @@index([createdAt])
  @@index([stripeTransferId])
  @@index([status])
  @@index([userId])
}

model PayoutAuditEvent {
  id        String   @id
  payoutId  String
  eventType String
  oldStatus String?
  newStatus String?
  adminId   String?
  metadata  String?
  createdAt DateTime @default(now())
  Payout    Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([eventType])
  @@index([payoutId])
}

model PayoutMethod {
  id         String   @id
  walletId   String
  iban       String
  holderName String
  bic        String?
  verified   Boolean  @default(false)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Wallet     Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

model Plan {
  id                String        @id
  name              String        @unique
  monthlyFee        Float         @default(0)
  yearlyFee         Float?
  currency          String        @default("EUR")
  commissionPercent Float         @default(14)
  walletFeePercent  Float         @default(3.5)
  featuresJson      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  CompanyPlan       CompanyPlan[]

  @@index([name])
}

model Refund {
  id          String    @id
  paymentId   String
  refundId    String?   @unique
  amountCents Int
  reason      String?
  status      String    @default("PENDING")
  initiatedBy String
  processedAt DateTime?
  failedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Payment     Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
  @@index([refundId])
  @@index([paymentId])
}

model RiskEvent {
  id            String     @id
  entityType    String
  entityId      String
  ruleId        String?
  ruleName      String
  ruleCategory  String
  weight        Int
  metadata      String?
  triggeredBy   String?
  relatedEntity String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime   @default(now())
  riskScoreId   String?
  RiskScore     RiskScore? @relation(fields: [riskScoreId], references: [id])

  @@index([createdAt])
  @@index([ruleName])
  @@index([entityId])
  @@index([entityType])
}

model RiskHistory {
  id          String     @id
  entityType  String
  entityId    String
  oldScore    Int
  newScore    Int
  scoreChange Int
  oldLevel    String
  newLevel    String
  reason      String?
  eventId     String?
  createdAt   DateTime   @default(now())
  riskScoreId String?
  RiskScore   RiskScore? @relation(fields: [riskScoreId], references: [id])

  @@index([createdAt])
  @@index([entityId])
  @@index([entityType])
}

model RiskRule {
  id             String   @id
  name           String   @unique
  description    String?
  entityType     String
  category       String
  condition      String
  weight         Int
  active         Boolean  @default(true)
  priority       Int      @default(0)
  maxTriggers    Int?
  createdBy      String?
  lastModifiedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@index([active])
  @@index([category])
  @@index([entityType])
}

model RiskScore {
  id               String        @id
  entityType       String
  entityId         String
  score            Int           @default(0)
  riskLevel        String        @default("GREEN")
  userScore        Int?
  companyScore     Int?
  transactionScore Int?
  factorsCount     Int           @default(0)
  lastEventAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime
  RiskEvent        RiskEvent[]
  RiskHistory      RiskHistory[]

  @@unique([entityType, entityId])
  @@index([score])
  @@index([riskLevel])
  @@index([entityId])
  @@index([entityType])
}

model RiskThreshold {
  id            String   @id
  name          String   @unique
  minValue      Int
  maxValue      Int
  allowAction   Boolean  @default(true)
  requireDelay  Boolean  @default(false)
  delayHours    Int?
  require2FA    Boolean  @default(false)
  requireGPS    Boolean  @default(false)
  createTicket  Boolean  @default(false)
  notifySupport Boolean  @default(false)
  mitigations   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([name])
}

model Role {
  id               String             @id
  name             String             @unique
  description      String?
  createdAt        DateTime           @default(now())
  UserRoleRelation UserRoleRelation[]

  @@index([name])
}

model SecurityFlag {
  id         String    @id
  userId     String
  type       String
  severity   String    @default("MEDIUM")
  active     Boolean   @default(true)
  notes      String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([active])
  @@index([type])
  @@index([userId])
}

model StripeEvent {
  id          String    @id
  type        String
  payload     String?
  processed   Boolean   @default(false)
  processedAt DateTime?
  errorCount  Int       @default(0)
  lastError   String?
  receivedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([receivedAt])
  @@index([processed])
  @@index([type])
}

model StripeRefund {
  id              String   @id
  stripeRefundId  String   @unique
  paymentId       String
  amountCents     Int
  reason          String?
  status          String
  stripeCreatedAt DateTime
  createdAt       DateTime @default(now())
  Payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([paymentId])
  @@index([stripeRefundId])
}

model SupportMessage {
  id            String        @id
  ticketId      String
  senderId      String
  senderRole    String
  message       String
  attachments   String?
  isInternal    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  SupportTicket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model SupportTicket {
  id             String           @id
  userId         String
  transportId    String?
  subject        String
  description    String
  priority       String           @default("NORMAL")
  status         String           @default("OPEN")
  category       String?
  assignedTo     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  resolvedAt     DateTime?
  closedAt       DateTime?
  SupportMessage SupportMessage[]
  User           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model SystemSetting {
  id          String   @id
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([key])
}

model TollSystem {
  id              String   @id
  countryCode     String
  countryName     String
  systemName      String
  systemType      String
  euro5Rate       Float?
  euro6Rate       Float?
  euro6eevRate    Float?
  vignetteDaily   Float?
  vignetteWeekly  Float?
  vignetteMonthly Float?
  vignetteYearly  Float?
  currency        String   @default("EUR")
  websiteUrl      String?
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@unique([countryCode, systemName])
  @@index([countryCode])
}

model TrackingPoint {
  id          String    @id
  transportId String
  driverId    String
  latitude    Float
  longitude   Float
  timestamp   DateTime  @default(now())
  speed       Float?
  heading     Float?
  Driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  Transport   Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([driverId])
  @@index([transportId])
}

model Transport {
  id                                           String                   @id
  shipperUserId                                String
  shipperCompanyId                             String?
  transportType                                String
  status                                       String                   @default("CREATED")
  pickupAddressId                              String
  deliveryAddressId                            String
  pickupDatetime                               DateTime
  pickupTimeFrom                               String?
  pickupTimeTo                                 String?
  deliveryDatetime                             DateTime?
  deliveryTimeFrom                             String?
  deliveryTimeTo                               String?
  description                                  String?
  distanceKm                                   Float?
  estimatedDuration                            Int?
  shipperBudget                                Float?
  agreedPrice                                  Float?
  currency                                     String                   @default("EUR")
  isInternational                              Boolean                  @default(false)
  transitCountries                             String?
  customsRequired                              Boolean                  @default(false)
  customsDocuments                             String?
  calculatedRoute                              String?
  tollCosts                                    Float?
  publishedAt                                  DateTime?
  assignedAt                                   DateTime?
  pickedUpAt                                   DateTime?
  deliveredAt                                  DateTime?
  completedAt                                  DateTime?
  cancelledAt                                  DateTime?
  cancellationReason                           String?
  createdAt                                    DateTime                 @default(now())
  updatedAt                                    DateTime
  Assignment                                   Assignment?
  Commission                                   Commission[]
  Document                                     Document[]
  MatchingSession                              MatchingSession[]
  Offer                                        Offer[]
  TrackingPoint                                TrackingPoint[]
  Address_Transport_deliveryAddressIdToAddress Address                  @relation("Transport_deliveryAddressIdToAddress", fields: [deliveryAddressId], references: [id])
  Address_Transport_pickupAddressIdToAddress   Address                  @relation("Transport_pickupAddressIdToAddress", fields: [pickupAddressId], references: [id])
  User                                         User                     @relation(fields: [shipperUserId], references: [id])
  TransportDetail                              TransportDetail?
  TransportStatusHistory                       TransportStatusHistory[]

  @@index([pickupDatetime])
  @@index([transportType])
  @@index([status])
  @@index([shipperUserId])
}

model TransportDetail {
  id                        String    @id
  transportId               String    @unique
  detailsJson               String
  vehicleRequirements       String?
  driverRequirements        String?
  internationalRequirements String?
  specialRequirements       String?
  weightKg                  Float?
  volumeM3                  Float?
  isHazmat                  Boolean   @default(false)
  isFragile                 Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime
  Transport                 Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)

  @@index([transportId])
}

model TransportStatusHistory {
  id          String    @id
  transportId String
  status      String
  changedBy   String?
  note        String?
  changedAt   DateTime  @default(now())
  Transport   Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)

  @@index([changedAt])
  @@index([transportId])
}

model User {
  id               String             @id
  email            String             @unique
  passwordHash     String
  firstName        String?
  lastName         String?
  phone            String?
  language         String             @default("de")
  status           String             @default("PENDING")
  lastLoginAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  Address          Address[]
  AuditLog         AuditLog[]
  Campaign         Campaign[]
  CompanyUser      CompanyUser[]
  Driver           Driver?
  Notification     Notification[]
  SecurityFlag     SecurityFlag[]
  SupportTicket    SupportTicket[]
  Transport        Transport[]
  UserRoleRelation UserRoleRelation[]
  Verification     Verification[]
  Wallet           Wallet?

  @@index([status])
  @@index([email])
}

model UserRoleRelation {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  Role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@index([userId])
}

model Vehicle {
  id                String              @id
  companyId         String
  type              String
  plateNumber       String              @unique
  brand             String?
  model             String?
  year              Int?
  lengthM           Float?
  widthM            Float?
  heightM           Float?
  maxPayloadKg      Float?
  volumeM3          Float?
  palletSpaces      Int?
  adrApproved       Boolean             @default(false)
  adrClasses        String?
  coolingAvailable  Boolean             @default(false)
  coolingMinTemp    Float?
  coolingMaxTemp    Float?
  hasLift           Boolean             @default(false)
  hasCrane          Boolean             @default(false)
  hasTank           Boolean             @default(false)
  tankCapacityL     Float?
  tunnelCodes       String?
  status            String              @default("ACTIVE")
  currentLocation   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  Assignment        Assignment[]
  DriverVehicle     DriverVehicle[]
  MatchingCandidate MatchingCandidate[]
  Offer             Offer[]
  Company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([type])
  @@index([companyId])
}

model Verification {
  id              String    @id
  userId          String
  type            String
  status          String    @default("PENDING")
  documentUrl     String?
  documentType    String?
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  User            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([type])
  @@index([userId])
}

model Wallet {
  id                String              @id
  ownerUserId       String?             @unique
  ownerCompanyId    String?             @unique
  balance           Float               @default(0)
  currency          String              @default("EUR")
  status            String              @default("ACTIVE")
  totalDeposited    Float               @default(0)
  totalWithdrawn    Float               @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  PayoutMethod      PayoutMethod[]
  Company           Company?            @relation(fields: [ownerCompanyId], references: [id], onDelete: Cascade)
  User              User?               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  WalletTransaction WalletTransaction[]

  @@index([status])
  @@index([ownerCompanyId])
  @@index([ownerUserId])
}

model WalletTransaction {
  id                 String    @id
  walletId           String
  type               String
  amount             Float
  currency           String    @default("EUR")
  relatedTransportId String?
  paymentId          String?
  description        String?
  reference          String?
  processedAt        DateTime?
  failedAt           DateTime?
  failureReason      String?
  createdAt          DateTime  @default(now())
  Payment            Payment?  @relation(fields: [paymentId], references: [id])
  Wallet             Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([relatedTransportId])
  @@index([type])
  @@index([walletId])
}
