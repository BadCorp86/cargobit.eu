// CargoBit Platform - Prisma Schema
// European Logistics Marketplace - Full Relational Model
// Version: 2.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  SUPPORT
  SHIPPER_COMPANY
  SHIPPER_PRIVATE
  DISPATCHER
  DRIVER_SELF_EMPLOYED
  MARKETER
}

enum UserStatus {
  ACTIVE
  PENDING
  BLOCKED
  SUSPENDED
}

enum CompanyType {
  SHIPPER
  CARRIER
  BOTH
}

enum CompanyStatus {
  ACTIVE
  PENDING
  SUSPENDED
  INACTIVE
}

enum VerificationType {
  KYC
  KYB
  DRIVER_LICENSE
  ADR
  VEHICLE
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SecurityFlagType {
  FRAUD_SUSPECTED
  PAYMENT_ISSUE
  DOCUMENT_ISSUE
  SUSPICIOUS_ACTIVITY
}

enum SecurityFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VehicleType {
  SPRINTER
  KOEFFER
  PLANE
  CURTAINSIDER
  KIPPER
  SILO
  MULDE
  TANKAUFLIEGER
  AUTOTRANSPORTER
  TIEFLADER
  TIEFBETT
  CONTAINERCHASSIS
  REEFER
  IBC_TRANSPORTER
  LANGAUFLIEGER
  JUMBO
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum TransportType {
  PALLET
  BULK
  LIQUID
  OVERSIZE
  LOWLOADER
  CAR_TRANSPORT
  COOLING
  HAZMAT
  CONTAINER
}

enum TransportStatus {
  CREATED
  PUBLISHED
  ASSIGNED
  IN_TRANSIT
  PICKUP_DONE
  DELIVERY_DONE
  COMPLETED
  CANCELLED
}

enum MatchingSessionStatus {
  STARTED
  RUNNING
  STOPPED
  COMPLETED
}

enum MatchingCandidateStatus {
  PENDING
  NOTIFIED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum WalletStatus {
  ACTIVE
  FROZEN
  INACTIVE
}

enum TransactionType {
  DEPOSIT
  PAYOUT
  FEE
  COMMISSION
  PAYMENT_IN
  PAYMENT_OUT
  REFUND
}

enum PlanName {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum CampaignStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  PAYOUT
  FRAUD_ALERT
}

// ============================================
// 1. KERNOBJEKTE: USERS, ROLES, COMPANIES
// ============================================

model Role {
  id          String      @id @default(cuid())
  name        UserRole    @unique
  description String?
  createdAt   DateTime    @default(now())
  
  userRoles   UserRoleRelation[]
  
  @@index([name])
}

model UserRoleRelation {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  phone           String?
  language        String    @default("de")
  status          UserStatus @default(PENDING)
  
  // Timestamps
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  roles           UserRoleRelation[]
  companyUsers    CompanyUser[]
  driver          Driver?
  verifications   Verification[]
  securityFlags   SecurityFlag[]
  addresses       Address[]
  wallet          Wallet?
  
  // Shipper relations
  transportsAsShipper   Transport[]         @relation("ShipperTransports")
  
  // Notifications & Support
  notifications   Notification[]
  supportTickets SupportTicket[]
  auditLogs       AuditLog[]
  
  // Marketing (for MARKETER role)
  campaigns       Campaign[]
  
  @@index([email])
  @@index([status])
}

model Company {
  id                  String        @id @default(cuid())
  name                String
  type                CompanyType   @default(SHIPPER)
  vatNumber           String?       @unique
  registrationNumber  String?
  country             String
  status              CompanyStatus @default(PENDING)
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  // Relations
  companyUsers        CompanyUser[]
  vehicles            Vehicle[]
  drivers             Driver[]
  addresses           Address[]
  plans               CompanyPlan[]
  campaigns           Campaign[]
  wallets             Wallet[]
  
  @@index([name])
  @@index([country])
}

model CompanyUser {
  companyId     String
  userId        String
  roleInCompany String    @default("member") // owner, admin, member
  createdAt     DateTime  @default(now())
  
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@id([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

// ============================================
// 2. VERIFIKATION, KYC/KYB, SICHERHEIT
// ============================================

model Verification {
  id              String            @id @default(cuid())
  userId          String
  type            VerificationType
  status          VerificationStatus @default(PENDING)
  documentUrl     String?
  documentType    String?
  rejectionReason String?
  
  reviewedAt      DateTime?
  reviewedBy      String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([status])
}

model SecurityFlag {
  id          String                @id @default(cuid())
  userId      String
  type        SecurityFlagType
  severity    SecurityFlagSeverity  @default(MEDIUM)
  active      Boolean               @default(true)
  notes       String?
  
  createdAt   DateTime              @default(now())
  resolvedAt  DateTime?
  
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([active])
}

// ============================================
// 3. FAHRZEUGE, FAHRER, FLOTTEN
// ============================================

model Vehicle {
  id              String        @id @default(cuid())
  companyId       String
  
  // Vehicle details
  type            VehicleType
  plateNumber     String        @unique
  brand           String?
  model           String?
  year            Int?
  
  // Dimensions & Capacity
  lengthM         Float?
  widthM          Float?
  heightM         Float?
  maxPayloadKg    Float?
  volumeM3        Float?
  palletSpaces    Int?
  
  // Features
  adrApproved     Boolean       @default(false)
  adrClasses      String?       // JSON array of ADR classes
  coolingAvailable Boolean      @default(false)
  coolingMinTemp  Float?        // Minimum temperature (°C)
  coolingMaxTemp  Float?        // Maximum temperature (°C)
  hasLift         Boolean       @default(false)
  hasCrane        Boolean       @default(false)
  hasTank         Boolean       @default(false)
  tankCapacityL   Float?
  
  // Tunnel codes for ADR
  tunnelCodes     String?       // JSON array
  
  // Status
  status          VehicleStatus @default(ACTIVE)
  currentLocation String?       // JSON: {lat, lng, timestamp, country}
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driverVehicles  DriverVehicle[]
  offers          Offer[]
  assignments     Assignment[]
  matchingCandidates MatchingCandidate[]
  
  @@index([companyId])
  @@index([type])
  @@index([status])
}

model Driver {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  companyId               String?
  
  // License info
  licenseNumber           String?
  licenseClass            String?   // C, CE, C1, C1E, etc.
  licenseExpiry           DateTime?
  
  // Driver card
  driverCardNumber        String?
  driverCardExpiry        DateTime?
  
  // ADR
  adrLicense              Boolean   @default(false)
  adrClasses              String?   // JSON array
  adrExpiry               DateTime?
  
  // International
  internationalExperience Boolean   @default(false)
  
  // Stats
  ratingAvg               Float     @default(0)
  ratingCount             Int       @default(0)
  completedTransports     Int       @default(0)
  cancelledTransports     Int       @default(0)
  damageCount             Int       @default(0)
  lastDamageAt            DateTime?
  
  // Availability
  isAvailable             Boolean   @default(true)
  currentLocation         String?   // JSON: {lat, lng, timestamp, country}
  
  // Languages
  spokenLanguages         String?   // JSON array: ["de", "en", "pl"]
  
  // Experience
  yearsExperience         Int?
  vehicleExperience       String?   // JSON array of vehicle types
  countryExperience       String?   // JSON array of countries
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  
  // Relations
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company                 Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  driverVehicles          DriverVehicle[]
  driverPermissions       DriverPermission[]
  offers                  Offer[]
  assignments             Assignment[]
  matchingCandidates      MatchingCandidate[]
  trackingPoints          TrackingPoint[]
  
  @@index([userId])
  @@index([companyId])
  @@index([isAvailable])
}

model DriverVehicle {
  driverId    String
  vehicleId   String
  isPrimary   Boolean   @default(false)
  assignedAt  DateTime  @default(now())
  
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@id([driverId, vehicleId])
  @@index([driverId])
  @@index([vehicleId])
}

// ============================================
// 4. TRANSPORTE & TRANSPORTDETAILS
// ============================================

model Address {
  id          String    @id @default(cuid())
  userId      String?
  companyId   String?
  
  label       String?   // "Home", "Office", "Warehouse"
  contactName String?
  contactPhone String?
  street      String
  streetNumber String?
  postalCode  String
  city        String
  state       String?
  country     String
  latitude    Float?
  longitude   Float?
  isDefault   Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Transport relations
  pickupForTransports   Transport[]  @relation("PickupAddress")
  deliveryForTransports Transport[]  @relation("DeliveryAddress")
  
  @@index([userId])
  @@index([companyId])
  @@index([country])
}

model Transport {
  id                    String          @id @default(cuid())
  
  // Participants
  shipperUserId         String
  shipperCompanyId      String?
  
  // Type & Status
  transportType         TransportType
  status                TransportStatus @default(CREATED)
  
  // Addresses
  pickupAddressId       String
  deliveryAddressId     String
  
  // Schedule
  pickupDatetime        DateTime
  pickupTimeFrom        String?
  pickupTimeTo          String?
  deliveryDatetime      DateTime?
  deliveryTimeFrom      String?
  deliveryTimeTo        String?
  
  // Description
  description           String?
  
  // Distance & Duration
  distanceKm            Float?
  estimatedDuration     Int?      // minutes
  
  // Pricing
  shipperBudget         Float?
  agreedPrice           Float?
  currency              String          @default("EUR")
  
  // International
  isInternational       Boolean         @default(false)
  transitCountries      String?         // JSON array
  customsRequired       Boolean         @default(false)
  customsDocuments      String?         // JSON array
  
  // Route
  calculatedRoute       String?         // JSON: route details
  tollCosts             Float?
  
  // Timestamps
  publishedAt           DateTime?
  assignedAt            DateTime?
  pickedUpAt            DateTime?
  deliveredAt           DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancellationReason    String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  shipperUser           User            @relation("ShipperTransports", fields: [shipperUserId], references: [id])
  pickupAddress         Address         @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  deliveryAddress       Address         @relation("DeliveryAddress", fields: [deliveryAddressId], references: [id])
  
  transportDetail       TransportDetail?
  matchingSessions      MatchingSession[]
  offers                Offer[]
  assignment            Assignment?
  statusHistory         TransportStatusHistory[]
  trackingPoints        TrackingPoint[]
  documents             Document[]
  commissions           Commission[]
  
  @@index([shipperUserId])
  @@index([status])
  @@index([transportType])
  @@index([pickupDatetime])
}

model TransportDetail {
  id            String    @id @default(cuid())
  transportId   String    @unique
  
  // JSON details based on transport type
  detailsJson   String    // JSON with type-specific fields
  
  // Requirements
  vehicleRequirements    String?   // JSON
  driverRequirements     String?   // JSON
  internationalRequirements String? // JSON
  specialRequirements    String?
  
  // Cargo info
  weightKg      Float?
  volumeM3      Float?
  isHazmat      Boolean   @default(false)
  isFragile     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  transport     Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
}

// ============================================
// 5. MATCHING, ANGEBOTE, ZUWEISUNG
// ============================================

model MatchingSession {
  id            String              @id @default(cuid())
  transportId   String
  status        MatchingSessionStatus @default(STARTED)
  autoAssign    Boolean             @default(false)
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  completedAt   DateTime?
  
  transport     Transport           @relation(fields: [transportId], references: [id], onDelete: Cascade)
  candidates    MatchingCandidate[]
  
  @@index([transportId])
  @@index([status])
}

model MatchingCandidate {
  id                    String                @id @default(cuid())
  matchingSessionId     String
  driverId              String
  vehicleId             String
  
  // Filter results
  hardFilterPassed      Boolean               @default(false)
  softRulesPassed       Boolean               @default(false)
  fraudSafe             Boolean               @default(true)
  internationalAllowed  Boolean               @default(true)
  
  // Score
  score                 Float                 @default(0)
  scoreBreakdown        String?               // JSON with detailed scores
  
  // Status
  status                MatchingCandidateStatus @default(PENDING)
  notifiedAt            DateTime?
  expiresAt             DateTime?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  matchingSession       MatchingSession       @relation(fields: [matchingSessionId], references: [id], onDelete: Cascade)
  driver                Driver                @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle               Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@unique([matchingSessionId, driverId, vehicleId])
  @@index([matchingSessionId])
  @@index([driverId])
  @@index([score])
  @@index([status])
}

model Offer {
  id              String      @id @default(cuid())
  transportId     String
  driverId        String
  vehicleId       String
  
  price           Float
  currency        String      @default("EUR")
  message         String?
  estimatedDuration Int?
  
  status          OfferStatus @default(PENDING)
  
  validUntil      DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  transport       Transport   @relation(fields: [transportId], references: [id], onDelete: Cascade)
  driver          Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@unique([transportId, driverId])
  @@index([transportId])
  @@index([driverId])
  @@index([status])
}

model Assignment {
  id            String    @id @default(cuid())
  transportId   String    @unique
  driverId      String
  vehicleId     String
  assignedBy    String
  
  assignedAt    DateTime  @default(now())
  
  transport     Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  driver        Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
  @@index([driverId])
}

// ============================================
// 6. STATUS, TRACKING, DOKUMENTE
// ============================================

model TransportStatusHistory {
  id            String    @id @default(cuid())
  transportId   String
  status        TransportStatus
  changedBy     String?
  note          String?
  
  changedAt     DateTime  @default(now())
  
  transport     Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
  @@index([changedAt])
}

model TrackingPoint {
  id            String    @id @default(cuid())
  transportId   String
  driverId      String
  
  latitude      Float
  longitude     Float
  timestamp     DateTime  @default(now())
  
  speed         Float?    // km/h
  heading       Float?    // degrees
  
  transport     Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  driver        Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
  @@index([driverId])
  @@index([timestamp])
}

model Document {
  id            String    @id @default(cuid())
  transportId   String?
  
  type          String    // cmr, lieferschein, rechnung, foto_pickup, foto_delivery, pod
  name          String
  description   String?
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  
  isGenerated   Boolean   @default(false)
  isSigned      Boolean   @default(false)
  signedAt      DateTime?
  signedByUrl   String?
  
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  transport     Transport? @relation(fields: [transportId], references: [id], onDelete: SetNull)
  
  @@index([transportId])
  @@index([type])
}

// ============================================
// 7. WALLET, ZAHLUNGEN, GEBÜHREN
// ============================================

model Wallet {
  id              String        @id @default(cuid())
  ownerUserId     String?       @unique
  ownerCompanyId  String?       @unique
  
  balance         Float         @default(0)
  currency        String        @default("EUR")
  status          WalletStatus  @default(ACTIVE)
  
  // Stats
  totalDeposited  Float         @default(0)
  totalWithdrawn  Float         @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  user            User?         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  company         Company?      @relation(fields: [ownerCompanyId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]
  payoutMethods   PayoutMethod[]
  
  @@index([ownerUserId])
  @@index([ownerCompanyId])
  @@index([status])
}

model WalletTransaction {
  id                  String          @id @default(cuid())
  walletId            String
  type                TransactionType
  amount              Float
  currency            String          @default("EUR")
  
  relatedTransportId  String?
  paymentId           String?         // Link to Payment for admin view
  description         String?
  reference           String?         // External reference
  
  processedAt         DateTime?
  failedAt            DateTime?
  failureReason       String?
  
  createdAt           DateTime        @default(now())
  
  wallet              Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  payment             Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  
  @@index([walletId])
  @@index([type])
  @@index([relatedTransportId])
  @@index([paymentId])
}

model PayoutMethod {
  id          String    @id @default(cuid())
  walletId    String
  
  iban        String
  holderName  String
  bic         String?
  verified    Boolean   @default(false)
  
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  wallet      Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  @@index([walletId])
}

model Commission {
  id                  String    @id @default(cuid())
  transportId         String
  
  plan                PlanName  @default(FREE)
  commissionPercent   Float
  commissionAmount    Float
  walletFeePercent    Float
  walletFeeAmount     Float
  
  createdAt           DateTime  @default(now())
  
  transport           Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
}

// ============================================
// 8. PRICING, PLÄNE, MARKETING
// ============================================

model Plan {
  id                  String    @id @default(cuid())
  name                PlanName  @unique
  
  monthlyFee          Float     @default(0)
  yearlyFee           Float?
  currency            String    @default("EUR")
  
  // Commission rates
  commissionPercent   Float     @default(14)
  walletFeePercent    Float     @default(3.5)
  
  // Features (JSON)
  featuresJson        String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  companyPlans        CompanyPlan[]
  
  @@index([name])
}

model CompanyPlan {
  id          String    @id @default(cuid())
  companyId   String
  planId      String
  
  validFrom   DateTime  @default(now())
  validTo     DateTime?
  
  createdAt   DateTime  @default(now())
  
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan        Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([planId])
}

model Campaign {
  id              String          @id @default(cuid())
  companyId       String?
  userId          String
  
  name            String
  description     String?
  
  position        String?         // banner_top, sidebar, listing_highlight
  bannerUrl       String?
  targetUrl       String?
  
  budget          Float           @default(0)
  spentAmount     Float           @default(0)
  currency        String          @default("EUR")
  
  status          CampaignStatus  @default(DRAFT)
  
  startDate       DateTime?
  endDate         DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stats           CampaignStats[]
  
  @@index([companyId])
  @@index([userId])
  @@index([status])
}

model CampaignStats {
  id          String    @id @default(cuid())
  campaignId  String
  
  date        DateTime  @default(now())
  impressions Int       @default(0)
  clicks      Int       @default(0)
  conversions Int       @default(0)
  
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  @@unique([campaignId, date])
  @@index([campaignId])
}

// ============================================
// 9. SUPPORT, TICKETS, LOGS
// ============================================

model SupportTicket {
  id          String      @id @default(cuid())
  userId      String
  transportId String?
  
  subject     String
  description String
  priority    String      @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  status      TicketStatus @default(OPEN)
  category    String?
  
  assignedTo  String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?
  
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    SupportMessage[]
  
  @@index([userId])
  @@index([status])
}

model SupportMessage {
  id          String    @id @default(cuid())
  ticketId    String
  senderId    String
  senderRole  String    // USER, SUPPORT, ADMIN
  
  message     String
  attachments String?   // JSON array of file URLs
  
  isInternal  Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  @@index([ticketId])
}

model AuditLog {
  id            String      @id @default(cuid())
  userId        String?
  
  action        AuditAction
  entityType    String      // user, transport, wallet, vehicle, etc.
  entityId      String?
  
  dataBefore    String?     // JSON
  dataAfter     String?     // JSON
  
  ipAddress     String?
  userAgent     String?
  
  createdAt     DateTime    @default(now())
  
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================
// 10. NOTIFICATIONS
// ============================================

model Notification {
  id          String    @id @default(cuid())
  userId      String
  
  type        String    // NEW_OFFER, TRANSPORT_UPDATE, PAYMENT, etc.
  title       String
  message     String
  data        String?   // JSON with additional data
  
  isRead      Boolean   @default(false)
  readAt      DateTime?
  
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?
  
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isRead])
}

// ============================================
// 11. DRIVER PERMISSIONS (International)
// ============================================

model DriverPermission {
  id              String    @id @default(cuid())
  driverId        String
  
  countryCode     String    // ISO 2-letter code
  countryName     String
  
  isAllowed       Boolean   @default(true)
  allowedAt       DateTime?
  expiresAt       DateTime?
  
  visaRequired    Boolean   @default(false)
  visaValid       Boolean   @default(false)
  visaExpiry      DateTime?
  
  tripsCompleted  Int       @default(0)
  lastTripAt      DateTime?
  
  documentUrl     String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  driver          Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@unique([driverId, countryCode])
  @@index([driverId])
  @@index([countryCode])
  @@index([isAllowed])
}

// ============================================
// 12. TOLL SYSTEMS & BORDER CROSSINGS
// ============================================

model TollSystem {
  id              String    @id @default(cuid())
  countryCode     String
  countryName     String
  
  systemName      String    // Toll Collect, eToll, myto, etc.
  systemType      String    // DISTANCE, VIGNETTE, HYBRID
  
  euro5Rate       Float?    // Rate per km
  euro6Rate       Float?
  euro6eevRate    Float?
  
  vignetteDaily   Float?
  vignetteWeekly  Float?
  vignetteMonthly Float?
  vignetteYearly  Float?
  
  currency        String    @default("EUR")
  websiteUrl      String?
  description     String?
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([countryCode, systemName])
  @@index([countryCode])
}

model BorderCrossing {
  id              String    @id @default(cuid())
  
  fromCountry     String
  toCountry       String
  crossingName    String
  
  latitude        Float?
  longitude       Float?
  
  adrAllowed      Boolean   @default(true)
  tunnelCode      String?
  
  open24h         Boolean   @default(true)
  openingHours    String?   // JSON
  
  avgWaitMinutes  Int?
  
  customsRequired Boolean   @default(true)
  customsType     String?   // EU_INTERNAL, EU_EXTERNAL
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([fromCountry, toCountry, crossingName])
  @@index([fromCountry])
  @@index([toCountry])
}

// ============================================
// 13. SYSTEM SETTINGS
// ============================================

model SystemSetting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String    // JSON
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([key])
}

// ============================================
// 14. RISK SCORING SYSTEM
// ============================================

enum RiskEntityType {
  USER
  COMPANY
  TRANSACTION
}

enum RiskLevel {
  GREEN
  YELLOW
  RED
}

model RiskScore {
  id            String          @id @default(cuid())
  entityType    RiskEntityType
  entityId      String
  
  score         Int             @default(0)    // 0-100
  riskLevel     RiskLevel       @default(GREEN)
  
  // Sub-scores (for combined scoring)
  userScore     Int?
  companyScore  Int?
  transactionScore Int?
  
  // Metadata
  factorsCount  Int             @default(0)
  lastEventAt   DateTime?
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  // Relations
  events        RiskEvent[]
  history       RiskHistory[]
  
  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([entityId])
  @@index([riskLevel])
  @@index([score])
}

model RiskEvent {
  id            String          @id @default(cuid())
  entityType    RiskEntityType
  entityId      String
  
  ruleId        String?         // Reference to RiskRule
  ruleName      String          // Rule identifier (e.g., "user_kyc_missing")
  ruleCategory  String          // USER, COMPANY, TRANSACTION
  
  weight        Int             // Score change (+ or -)
  metadata      String?         // JSON with details (IP, amount, GPS, etc.)
  
  // Context
  triggeredBy   String?         // User ID or system process
  relatedEntity String?         // Related transport/offer/wallet ID
  ipAddress     String?
  userAgent     String?
  
  createdAt     DateTime        @default(now())
  
  // Relations
  riskScore     RiskScore?      @relation(fields: [riskScoreId], references: [id], onDelete: SetNull)
  riskScoreId   String?
  
  @@index([entityType])
  @@index([entityId])
  @@index([ruleName])
  @@index([createdAt])
}

model RiskRule {
  id            String          @id @default(cuid())
  name          String          @unique  // e.g., "user_kyc_missing"
  description   String?
  
  entityType    RiskEntityType
  category      String          // USER, COMPANY, TRANSACTION, BEHAVIOR, DOCUMENT
  
  // Condition as JSON
  condition     String          // JSON: { "field": "kyc_status", "equals": "missing" }
  
  weight        Int             // Score change (+ increases risk, - decreases risk)
  active        Boolean         @default(true)
  
  // Configuration
  priority      Int             @default(0)  // Higher priority = evaluated first
  maxTriggers   Int?            // Max times this rule can trigger per day/week
  
  // Metadata
  createdBy     String?
  lastModifiedBy String?
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  @@index([entityType])
  @@index([category])
  @@index([active])
}

model RiskHistory {
  id            String          @id @default(cuid())
  entityType    RiskEntityType
  entityId      String
  
  oldScore      Int
  newScore      Int
  scoreChange   Int             // newScore - oldScore
  
  oldLevel      RiskLevel
  newLevel      RiskLevel
  
  reason        String?         // Human-readable reason
  eventId       String?         // Reference to triggering RiskEvent
  
  createdAt     DateTime        @default(now())
  
  // Relations
  riskScore     RiskScore?      @relation(fields: [riskScoreId], references: [id], onDelete: SetNull)
  riskScoreId   String?
  
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

// ============================================
// 15. RISK THRESHOLDS CONFIGURATION
// ============================================

model RiskThreshold {
  id            String          @id @default(cuid())
  name          String          @unique  // "green", "yellow", "red"

  minValue      Int             // Inclusive
  maxValue      Int             // Inclusive

  // Actions
  allowAction   Boolean         @default(true)
  requireDelay  Boolean         @default(false)
  delayHours    Int?
  require2FA    Boolean         @default(false)
  requireGPS    Boolean         @default(false)
  createTicket  Boolean         @default(false)
  notifySupport Boolean         @default(false)

  // Mitigations as JSON
  mitigations   String?         // JSON array of mitigation actions

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([name])
}

// ============================================
// 16. PARTNER PORTAL SYSTEM
// ============================================

enum PartnerType {
  INSURANCE
  ADS
}

enum PartnerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum BillingStatus {
  OPEN
  PAID
  OVERDUE
  CANCELLED
}

enum AdSlotType {
  MARKETPLACE_SIDEBAR
  MARKETPLACE_BANNER
  LISTING_HIGHLIGHT
  CHECKOUT_UPSELL
  EMAIL_SPONSOR
}

enum CampaignPricingModel {
  CPC  // Cost per Click
  CPM  // Cost per Mille (1000 impressions)
  CPA  // Cost per Action
}

model Partner {
  id              String        @id @default(cuid())

  // Basic Info
  name            String        // Company name
  type            PartnerType   // insurance or ads
  contactEmail    String
  contactPhone    String?
  contactPerson   String?       // Name of contact person
  website         String?

  // Legal
  vatNumber       String?       @unique
  registrationNumber String?
  country         String?
  address         String?

  // Status
  status          PartnerStatus @default(PENDING)
  statusReason    String?       // Reason for rejection/suspension

  // Documents
  contractUrl     String?       // Signed contract PDF
  complianceDocs  String?       // JSON array of document URLs

  // Configuration
  webhookUrl      String?
  testMode        Boolean       @default(true)
  liveModeEnabled Boolean       @default(false)

  // Commission
  commissionRate  Float         @default(10.0)  // Partner's commission percentage

  // Limits
  rateLimitPerMin Int           @default(300)
  burstLimit      Int           @default(100)

  // Timestamps
  approvedAt      DateTime?
  approvedBy      String?       // Admin user ID
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  apiKeys         PartnerApiKey[]
  insuranceProducts InsuranceProduct[]
  adCampaigns     PartnerAdCampaign[]
  billings        PartnerBilling[]
  policies         InsurancePolicy[]
  adStats          PartnerAdStat[]

  @@index([type])
  @@index([status])
  @@index([contactEmail])
}

model PartnerApiKey {
  id              String        @id @default(cuid())
  partnerId       String

  // Key Info
  name            String        // "Production Key", "Test Key"
  apiKey          String        @unique  // The actual API key (hashed in production)
  apiKeyPrefix    String        // First 8 chars for identification

  // Scopes
  scopes          String        // JSON array: ["insurance:read", "insurance:write", "ads:read", "ads:write", "billing:read"]

  // Status
  status          ApiKeyStatus  @default(ACTIVE)
  isTestKey       Boolean       @default(true)

  // Limits
  rateLimitPerMin Int?
  lastUsedAt      DateTime?

  // Timestamps
  createdAt       DateTime      @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  revokedReason   String?

  // Relations
  partner         Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([apiKey])
  @@index([status])
}

model InsuranceProduct {
  id              String        @id @default(cuid())
  partnerId       String

  // Product Info
  name            String        // "Standard Cargo", "Premium Cargo", "ADR Coverage"
  description     String?
  productCode     String?       // Internal product code

  // Coverage
  coverageEur     Float         // Maximum coverage in EUR
  deductibleEur   Float         @default(0)

  // Pricing
  basePremiumEur  Float         // Base premium in EUR
  premiumType     String        @default("fixed")  // fixed, percentage, per_kg

  // Risk Modifiers
  riskModifiers   String?       // JSON: { "yellow": 1.2, "red": 1.5 }
  routeModifiers  String?       // JSON for international routes
  cargoModifiers  String?       // JSON for cargo types

  // Coverage Options
  coversTheft     Boolean       @default(true)
  coversDelay     Boolean       @default(false)
  coversDamage    Boolean       @default(true)
  coversHazmat    Boolean       @default(false)

  // Additional Options (available add-ons)
  additionalOptions String?     // JSON array of available options

  // Status
  isActive        Boolean       @default(true)

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  partner         Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  policies         InsurancePolicy[]

  @@index([partnerId])
  @@index([isActive])
}

model InsurancePolicy {
  id              String        @id @default(cuid())
  partnerId       String
  productId       String
  transportId     String?       // Link to transport

  // Policy Info
  policyNumber    String        @unique
  status          String        @default("active")  // active, cancelled, expired, claimed

  // Coverage
  coverageEur     Float
  premiumEur      Float
  deductibleEur   Float

  // Insured Party
  insuredUserId   String?
  insuredName     String
  insuredEmail    String

  // Risk Assessment
  riskLevel       String?       // green, yellow, red
  riskScore       Int?

  // Route Info
  pickupCountry   String?
  deliveryCountry String?
  transitCountries String?      // JSON array

  // Cargo Info
  cargoDescription String?
  cargoValueEur   Float?

  // Premium Details
  basePremium     Float
  riskSurcharge   Float         @default(0)
  totalPremium    Float

  // Commission
  partnerCommission Float

  // Dates
  validFrom       DateTime
  validUntil      DateTime
  cancelledAt     DateTime?

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  partner         Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  product         InsuranceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

model PartnerAdCampaign {
  id              String        @id @default(cuid())
  partnerId       String

  // Campaign Info
  name            String
  description     String?

  // Placement
  slot            AdSlotType    @default(MARKETPLACE_SIDEBAR)

  // Creative
  bannerUrl       String?
  bannerAlt       String?
  targetUrl       String
  callToAction    String?       // "Jetzt absichern", "Mehr erfahren"

  // Budget
  budgetEur       Float
  spentEur        Float         @default(0)
  currency        String        @default("EUR")

  // Pricing Model
  pricingModel    CampaignPricingModel @default(CPC)
  cpcEur          Float?        // Cost per click
  cpmEur          Float?        // Cost per 1000 impressions
  cpaEur          Float?        // Cost per action/conversion

  // Targeting
  targeting       String?       // JSON: { "riskLevels": ["yellow", "red"], "roles": ["shipper"], "countries": ["DE", "AT"] }
  languageTarget  String?       // JSON array of language codes

  // Schedule
  startDate       DateTime?
  endDate         DateTime?

  // Status
  status          CampaignStatus @default(DRAFT)

  // Stats (aggregated)
  totalImpressions Int          @default(0)
  totalClicks     Int           @default(0)
  totalConversions Int          @default(0)

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  partner         Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  dailyStats      PartnerAdStat[]

  @@index([partnerId])
  @@index([status])
  @@index([slot])
}

model PartnerAdStat {
  id              String        @id @default(cuid())
  partnerId       String
  campaignId      String

  // Date
  date            DateTime

  // Metrics
  impressions     Int           @default(0)
  clicks          Int           @default(0)
  conversions     Int           @default(0)

  // Costs
  costEur         Float         @default(0)

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  partner         Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  campaign        PartnerAdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([partnerId])
  @@index([campaignId])
  @@index([date])
}

model PartnerBilling {
  id              String        @id @default(cuid())
  partnerId       String

  // Billing Info
  invoiceNumber   String        @unique
  type            PartnerType   // insurance or ads

  // Period
  periodMonth     Int           // 1-12
  periodYear      Int

  // Amounts
  grossAmountEur  Float
  commissionEur   Float         // CargoBit's commission
  netAmountEur    Float         // Partner receives this
  vatEur          Float?
  totalEur        Float

  // Status
  status          BillingStatus @default(OPEN)

  // Payment
  paidAt          DateTime?
  paymentMethod   String?
  paymentReference String?

  // Documents
  invoiceUrl      String?       // PDF URL

  // Details (JSON)
  lineItems       String?       // JSON array of billing line items

  // Timestamps
  dueDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  partner         Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([status])
  @@index([periodYear, periodMonth])
}

// ============================================
// 22. ADMIN USERS (RBAC)
// ============================================

enum AdminRole {
  ADMIN     // Full access: System, Users, Finance, Disputes
  FINANCE   // Payments, Refunds, Payouts
  SUPPORT   // Disputes, Jobs, User-Sperren (no direct payouts/refunds)
}

model AdminUser {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String
  
  // 2FA
  totpSecret      String?
  is2faEnabled    Boolean     @default(false)
  backupCodes     String?     // JSON array of backup codes
  
  // Role
  role            AdminRole   @default(SUPPORT)
  
  // Status
  isActive        Boolean     @default(true)
  lastLoginAt     DateTime?
  
  // Failed attempts
  failedAttempts  Int         @default(0)
  lockedUntil     DateTime?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  sessions        AdminSession[]
  adminAuditLogs  AdminAuditLog[]
  
  @@index([email])
  @@index([role])
  @@index([isActive])
}

model AdminSession {
  id              String    @id @default(cuid())
  adminId         String
  
  // Tokens
  token           String    @unique
  refreshToken    String    @unique
  
  // Context
  ipAddress       String
  userAgent       String?
  deviceId        String?
  
  // Expiry
  expiresAt       DateTime
  refreshExpiresAt DateTime
  
  // Timestamps
  createdAt       DateTime  @default(now())
  lastActivity    DateTime  @default(now())
  
  // Relations
  admin           AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  @@index([adminId])
  @@index([token])
  @@index([expiresAt])
}

model AdminAuditLog {
  id            String    @id @default(cuid())
  adminId       String
  
  // Action
  action        String    // login, logout, refund, payout, user_block, etc.
  entityType    String    // payment, user, job, dispute
  entityId      String?
  
  // Data
  dataBefore    String?   // JSON
  dataAfter     String?   // JSON
  
  // Context
  ipAddress     String?
  userAgent     String?
  
  createdAt     DateTime  @default(now())
  
  // Relations
  admin         AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  @@index([adminId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================
// 23. PAYMENTS & TRANSACTIONS (Admin View)
// ============================================

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RefundStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
}

model Payment {
  id                  String        @id @default(cuid())
  
  // Stripe references
  paymentIntentId     String?       @unique  // Stripe PaymentIntent ID
  chargeId            String?                // Stripe Charge ID
  
  // Related entities
  jobId               String?       // Link to Transport/Job
  shipperId           String        // User who paid
  transporterId       String?       // Driver/Transporter receiving payment
  
  // Amounts
  amountCents         Int           // Amount in cents
  currency            String        @default("EUR")
  platformFeeCents    Int           @default(0)  // 3.5% platform fee
  transporterAmountCents Int?       // Amount going to transporter
  
  // Status
  status              PaymentStatus @default(PENDING)
  
  // Metadata
  description         String?
  metadata            String?       // JSON with additional info
  
  // Timestamps
  paidAt              DateTime?
  failedAt            DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  // Relations
  refunds             Refund[]
  walletTransactions  WalletTransaction[]
  auditEvents         PaymentAuditEvent[]
  
  @@index([paymentIntentId])
  @@index([jobId])
  @@index([shipperId])
  @@index([status])
  @@index([createdAt])
}

model Refund {
  id              String        @id @default(cuid())
  paymentId       String
  
  // Stripe reference
  refundId        String?       @unique  // Stripe Refund ID
  
  // Amount
  amountCents     Int
  reason          String?
  
  // Status
  status          RefundStatus  @default(PENDING)
  
  // Admin info
  initiatedBy     String        // Admin user ID
  processedAt     DateTime?
  failedAt        DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  payment         Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  @@index([paymentId])
  @@index([refundId])
  @@index([status])
  @@index([createdAt])
}

model PaymentAuditEvent {
  id              String    @id @default(cuid())
  paymentId       String
  
  // Event
  eventType       String    // created, paid, failed, refunded, etc.
  oldStatus       String?
  newStatus       String
  
  // Context
  adminId         String?   // If triggered by admin
  metadata        String?   // JSON
  
  createdAt       DateTime  @default(now())
  
  // Relations
  payment         Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  @@index([paymentId])
  @@index([eventType])
  @@index([createdAt])
}

// ============================================
// 24. STRIPE EVENT IDEMPOTENCY
// ============================================

model StripeEvent {
  id            String    @id   // Stripe event ID (evt_xxx)
  
  // Event details
  type          String                    // payment_intent.succeeded, charge.refunded, etc.
  payload       String?                   // Full JSON payload
  
  // Processing status
  processed     Boolean   @default(false)
  processedAt   DateTime?
  
  // Error tracking
  errorCount    Int       @default(0)
  lastError     String?
  
  // Timestamps
  receivedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  
  @@index([type])
  @@index([processed])
  @@index([receivedAt])
}

// ============================================
// 25. DISPUTES SYSTEM
// ============================================

enum DisputeStatus {
  OPEN          // New dispute, awaiting review
  IN_PROGRESS   // Being investigated
  AWAITING_INFO // Waiting for additional info from parties
  RESOLVED      // Resolved (refunded/rejected)
  CLOSED        // Closed without action
}

enum DisputeReason {
  DAMAGE              // Goods damaged during transport
  DELAY               // Significant delivery delay
  LOST_CARGO          // Cargo lost
  WRONG_DELIVERY      // Delivered to wrong address
  QUALITY_ISSUE       // Quality of service issue
  PRICE_DISPUTE       // Disagreement on pricing
  DRIVER_BEHAVIOR     // Driver behavior complaint
  DOCUMENTATION       // Missing/incorrect documents
  OTHER               // Other reasons
}

enum DisputeResolution {
  REFUND_FULL       // Full refund to shipper
  REFUND_PARTIAL    // Partial refund to shipper
  REJECT            // Reject dispute, no refund
  COMPENSATION      // Compensation paid (not from transporter)
  RESEND            // Re-send cargo
}

model Dispute {
  id              String            @id @default(cuid())
  
  // Related Job
  jobId           String            // Link to Transport/Job
  
  // Parties
  createdById     String            // User who created the dispute
  againstId       String?           // User/Driver against whom the dispute is filed
  
  // Details
  reason          DisputeReason
  subject         String
  description     String
  
  // Amount in dispute
  disputedAmountCents Int?
  
  // Status
  status          DisputeStatus     @default(OPEN)
  
  // Resolution
  resolution      DisputeResolution?
  resolutionText  String?
  refundAmountCents Int?
  
  // Admin handling
  assignedToId    String?           // Admin user ID
  resolvedById    String?           // Admin who resolved
  resolvedAt      DateTime?
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  messages        DisputeMessage[]
  attachments     DisputeAttachment[]
  auditEvents     DisputeAuditEvent[]
  
  @@index([jobId])
  @@index([createdById])
  @@index([status])
  @@index([reason])
  @@index([createdAt])
}

model DisputeMessage {
  id            String    @id @default(cuid())
  disputeId     String
  
  // Sender
  senderId      String
  senderType    String    // USER, DRIVER, ADMIN, SUPPORT
  
  // Content
  message       String
  attachments   String?   // JSON array of attachment URLs
  
  // Visibility
  isInternal    Boolean   @default(false)  // Internal note (not visible to parties)
  
  createdAt     DateTime  @default(now())
  
  // Relations
  dispute       Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  
  @@index([disputeId])
  @@index([senderId])
  @@index([createdAt])
}

model DisputeAttachment {
  id            String    @id @default(cuid())
  disputeId     String
  messageId     String?   // Optional link to message
  
  // File info
  fileName      String
  fileUrl       String
  fileType      String    // image, pdf, document
  fileSize      Int?      // bytes
  
  // Uploader
  uploadedBy    String    // User ID
  
  createdAt     DateTime  @default(now())
  
  // Relations
  dispute       Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  
  @@index([disputeId])
}

model DisputeAuditEvent {
  id            String    @id @default(cuid())
  disputeId     String
  
  // Event
  eventType     String    // created, status_change, message, resolved, etc.
  oldStatus     String?
  newStatus     String?
  
  // Context
  adminId       String?   // If triggered by admin
  metadata      String?   // JSON
  
  createdAt     DateTime  @default(now())
  
  // Relations
  dispute       Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  
  @@index([disputeId])
  @@index([eventType])
  @@index([createdAt])
}
