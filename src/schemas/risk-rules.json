{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CargoBit Risk Engine Rules",
  "description": "Vollstaendiges Regelwerk fuer die Risk-Scoring-Engine",
  "version": "2.0.0",
  "lastUpdated": "2026-04-15",

  "riskThresholds": {
    "green": {
      "min": 0,
      "max": 30,
      "label": "GREEN",
      "description": "Niedriges Risiko - Aktion normal erlaubt",
      "recommendation": "ALLOW",
      "mitigations": []
    },
    "yellow": {
      "min": 31,
      "max": 60,
      "label": "YELLOW",
      "description": "Erhoehtes Risiko - Aktion mit Einschraenkungen",
      "recommendation": "ALLOW_WITH_MITIGATIONS",
      "mitigations": [
        "DELAY_24H",
        "EXTRA_LOGGING",
        "SUPPORT_NOTIFICATION"
      ]
    },
    "red": {
      "min": 61,
      "max": 100,
      "label": "RED",
      "description": "Hohes Risiko - Aktion blockiert",
      "recommendation": "BLOCK",
      "mitigations": [
        "MANUAL_REVIEW_REQUIRED",
        "SUPPORT_NOTIFICATION",
        "CREATE_TICKET"
      ]
    }
  },

  "scoreWeights": {
    "user": 0.40,
    "company": 0.30,
    "transaction": 0.30
  },

  "userRiskRules": [
    {
      "id": "user_kyc_missing",
      "name": "KYC_UNVOLLSTAENDIG",
      "description": "KYC-Verifizierung nicht abgeschlossen",
      "entityType": "USER",
      "category": "DOCUMENT",
      "condition": {
        "field": "kyc_status",
        "equals": "missing"
      },
      "weight": 20,
      "priority": 10,
      "active": true
    },
    {
      "id": "user_kyc_pending",
      "name": "KYC_AUSSTEHEND",
      "description": "KYC-Verifizierung laeuft noch",
      "entityType": "USER",
      "category": "DOCUMENT",
      "condition": {
        "field": "kyc_status",
        "equals": "pending"
      },
      "weight": 10,
      "priority": 9,
      "active": true
    },
    {
      "id": "user_new_iban",
      "name": "NEUE_IBAN_UNTER_48H",
      "description": "Neue IBAN in den letzten 48h hinzugefuegt",
      "entityType": "USER",
      "category": "USER",
      "condition": {
        "field": "iban_age_hours",
        "less_than": 48
      },
      "weight": 15,
      "priority": 8,
      "active": true
    },
    {
      "id": "user_many_cancellations",
      "name": "VIELE_STORNOS",
      "description": "Hohe Stornorate in kurzer Zeit",
      "entityType": "USER",
      "category": "BEHAVIOR",
      "condition": {
        "field": "cancellation_rate",
        "greater_than": 0.3
      },
      "weight": 10,
      "priority": 7,
      "active": true
    },
    {
      "id": "user_moderate_cancellations",
      "name": "ERHOEHITE_STORNOS",
      "description": "Moderate Stornorate",
      "entityType": "USER",
      "category": "BEHAVIOR",
      "condition": {
        "and": [
          { "field": "cancellation_rate", "greater_than": 0.15 },
          { "field": "cancellation_rate", "less_than_or_equal": 0.3 }
        ]
      },
      "weight": 5,
      "priority": 6,
      "active": true
    },
    {
      "id": "user_new_account",
      "name": "NEUES_KONTO",
      "description": "Konto juenger als 7 Tage",
      "entityType": "USER",
      "category": "USER",
      "condition": {
        "field": "account_age_days",
        "less_than": 7
      },
      "weight": 5,
      "priority": 5,
      "active": true
    },
    {
      "id": "user_very_new_account",
      "name": "SEHR_NEUES_KONTO",
      "description": "Konto juenger als 24 Stunden",
      "entityType": "USER",
      "category": "USER",
      "condition": {
        "field": "account_age_days",
        "less_than": 1
      },
      "weight": 10,
      "priority": 6,
      "active": true
    },
    {
      "id": "user_active_security_flag",
      "name": "AKTIVE_SICHERHEITS_FLAG",
      "description": "Aktive Sicherheits-Flags vorhanden",
      "entityType": "USER",
      "category": "DOCUMENT",
      "condition": {
        "field": "active_security_flags",
        "greater_than": 0
      },
      "weight": 25,
      "priority": 15,
      "active": true
    },
    {
      "id": "user_critical_security_flag",
      "name": "KRITISCHE_SICHERHEITS_FLAG",
      "description": "Kritische Sicherheits-Flags",
      "entityType": "USER",
      "category": "DOCUMENT",
      "condition": {
        "field": "critical_security_flags",
        "greater_than": 0
      },
      "weight": 35,
      "priority": 20,
      "active": true
    },
    {
      "id": "user_recent_fraud_flag",
      "name": "KUERZLICHER_BETRUGSVERDACHT",
      "description": "Betrugsverdacht in den letzten 90 Tagen",
      "entityType": "USER",
      "category": "BEHAVIOR",
      "condition": {
        "field": "fraud_flag_days",
        "less_than": 90
      },
      "weight": 30,
      "priority": 18,
      "active": true
    },
    {
      "id": "user_multiple_failed_logins",
      "name": "MEHRERE_FEHLGESCHLAGENE_LOGINS",
      "description": "Mehrere fehlgeschlagene Login-Versuche",
      "entityType": "USER",
      "category": "BEHAVIOR",
      "condition": {
        "field": "failed_logins_7d",
        "greater_than": 5
      },
      "weight": 8,
      "priority": 4,
      "active": true
    },
    {
      "id": "user_many_country_changes",
      "name": "VIELE_LAENDERWECHSEL",
      "description": "Ungewoehnlich viele Laenderwechsel",
      "entityType": "USER",
      "category": "BEHAVIOR",
      "condition": {
        "field": "distinct_countries_30d",
        "greater_than": 10
      },
      "weight": 12,
      "priority": 4,
      "active": true
    },
    {
      "id": "user_low_rating",
      "name": "NIEDRIGE_BEWERTUNG",
      "description": "Bewertung unter 3.0 bei min. 5 Bewertungen",
      "entityType": "USER",
      "category": "BEHAVIOR",
      "condition": {
        "and": [
          { "field": "rating_avg", "less_than": 3.0 },
          { "field": "rating_count", "greater_than_or_equal": 5 }
        ]
      },
      "weight": 10,
      "priority": 5,
      "active": true
    },
    {
      "id": "user_high_rating",
      "name": "HOHE_BEWERTUNG",
      "description": "Exzellente Bewertung ueber 4.7",
      "entityType": "USER",
      "category": "BEHAVIOR",
      "condition": {
        "and": [
          { "field": "rating_avg", "greater_than": 4.7 },
          { "field": "rating_count", "greater_than_or_equal": 10 }
        ]
      },
      "weight": -10,
      "priority": 3,
      "active": true
    },
    {
      "id": "user_long_history",
      "name": "LANGE_HISTORIE",
      "description": "Konto laenger als 1 Jahr aktiv",
      "entityType": "USER",
      "category": "USER",
      "condition": {
        "field": "account_age_days",
        "greater_than": 365
      },
      "weight": -10,
      "priority": 2,
      "active": true
    },
    {
      "id": "user_many_completed_transports",
      "name": "VIELE_ABGESCHLOSSENE_TRANSPORTE",
      "description": "Ueber 50 erfolgreiche Transporte",
      "entityType": "USER",
      "category": "USER",
      "condition": {
        "field": "completed_transports",
        "greater_than_or_equal": 50
      },
      "weight": -5,
      "priority": 2,
      "active": true
    },
    {
      "id": "user_enhanced_kyc",
      "name": "ERWEITERTES_KYC",
      "description": "Erweitertes KYC Level erreicht",
      "entityType": "USER",
      "category": "DOCUMENT",
      "condition": {
        "field": "kyc_level",
        "equals": "enhanced"
      },
      "weight": -8,
      "priority": 3,
      "active": true
    }
  ],

