  "mitigationActions": {
    "DELAY_24H": {
      "name": "24H_DELAY",
      "description": "24-stuendige Wartezeit",
      "applicableActions": ["INITIATE_PAYOUT", "HIGH_VALUE_TRANSPORT"],
      "requiresUserConfirmation": false
    },
    "EXTRA_LOGGING": {
      "name": "ERWEITERTES_LOGGING",
      "description": "Erweitertes Logging aktivieren",
      "applicableActions": ["*"],
      "requiresUserConfirmation": false
    },
    "GPS_VERIFICATION": {
      "name": "GPS_VERIFIZIERUNG",
      "description": "GPS-Standort verifizieren",
      "applicableActions": ["ACCEPT_JOB", "UPDATE_STATUS", "ASSIGN_DRIVER"],
      "requiresUserConfirmation": true
    },
    "TWO_FACTOR_CHALLENGE": {
      "name": "2FA_CHALLENGE",
      "description": "2-Faktor-Authentifizierung erforderlich",
      "applicableActions": ["INITIATE_PAYOUT", "ACCEPT_OFFER"],
      "requiresUserConfirmation": true
    },
    "DOCUMENT_RECHECK": {
      "name": "DOKUMENTEN_CHECK",
      "description": "Dokumente erneut pruefen",
      "applicableActions": ["ACCEPT_JOB", "CREATE_TRANSPORT"],
      "requiresUserConfirmation": false
    },
    "SUPPORT_NOTIFICATION": {
      "name": "SUPPORT_BENACHRICHTIGUNG",
      "description": "Support-Team benachrichtigen",
      "applicableActions": ["*"],
      "requiresUserConfirmation": false
    },
    "AMOUNT_LIMIT": {
      "name": "BETRAGSLIMIT",
      "description": "Betrag auf Maximum begrenzen",
      "applicableActions": ["INITIATE_PAYOUT"],
      "requiresUserConfirmation": false
    },
    "MANUAL_REVIEW_REQUIRED": {
      "name": "MANUELLE_PRUEFUNG",
      "description": "Manuelle Pruefung durch Support erforderlich",
      "applicableActions": ["*"],
      "requiresUserConfirmation": false
    },
    "CREATE_TICKET": {
      "name": "TICKET_ERSTELLEN",
      "description": "Support-Ticket automatisch erstellen",
      "applicableActions": ["*"],
      "requiresUserConfirmation": false
    }
  },

  "examples": {
    "userRiskCalculation": {
      "description": "Beispiel: UserRiskScore Berechnung",
      "input": {
        "userId": "user_123",
        "kyc_status": "missing",
        "iban_age_hours": 24,
        "rating_avg": 4.8,
        "account_age_days": 100
      },
      "triggeredRules": [
        { "rule": "user_kyc_missing", "weight": 20 },
        { "rule": "user_new_iban", "weight": 15 },
        { "rule": "user_high_rating", "weight": -10 }
      ],
      "result": {
        "score": 25,
        "level": "GREEN",
        "recommendation": "ALLOW"
      }
    },
    "companyRiskCalculation": {
      "description": "Beispiel: CompanyRiskScore Berechnung",
      "input": {
        "companyId": "company_456",
        "kyb_status": "approved",
        "fraud_flags": 0,
        "company_age_years": 5
      },
      "triggeredRules": [
        { "rule": "company_good_history", "weight": -10 }
      ],
      "result": {
        "score": 0,
        "level": "GREEN",
        "recommendation": "ALLOW"
      }
    },
    "transactionRiskCalculation": {
      "description": "Beispiel: TransactionRiskScore Berechnung",
      "input": {
        "amount": 75000,
        "international": true,
        "hazmat": true,
        "has_escrow": true
      },
      "triggeredRules": [
        { "rule": "tx_high_amount", "weight": 20 },
        { "rule": "tx_international_hazardous", "weight": 20 },
        { "rule": "tx_has_escrow", "weight": -5 }
      ],
      "result": {
        "score": 35,
        "level": "YELLOW",
        "recommendation": "ALLOW_WITH_MITIGATIONS"
      }
    },
    "combinedRiskCalculation": {
      "description": "Beispiel: CombinedRiskScore Berechnung",
      "input": {
        "userScore": 25,
        "companyScore": 10,
        "transactionScore": 35
      },
      "calculation": {
        "user": "25 * 0.40 = 10",
        "company": "10 * 0.30 = 3",
        "transaction": "35 * 0.30 = 10.5"
      },
      "result": {
        "score": 23.5,
        "level": "GREEN",
        "recommendation": "ALLOW"
      }
    }
  }
}
