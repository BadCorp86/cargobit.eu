{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@agents/*": ["./multi-agent/agents/*"],
      "@pipeline/*": ["./pipeline/*"]
    }
  },
  "include": [
    "multi-agent/**/*",
    "pipeline/**/*",
    "output/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "output/tests"
  ]
}
